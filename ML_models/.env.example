# =============================================================
# backend/env.example.txt
#
# HOW TO USE:
#   Copy/rename this file to exactly:  .env
#   Then fill in your real values below.
#   The .env file is in .gitignore — NEVER committed to Git.
# =============================================================

# ── MQTT Broker ───────────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_SENSOR_DATA=smart_agriculture/sensor_data
MQTT_CLIENT_ID=fastapi_backend_01

# ── FastAPI Server ────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=True
APP_TITLE=Smart Agriculture API
APP_VERSION=1.0.0

# ── MongoDB ───────────────────────────────────────────────────
MONGO_URI=mongodb+srv://SmartAgricul42:Smart_Agricult_4242@smart-agriculture.jslg94i.mongodb.net/Agricult?appName=Smart-Agriculture
MONGO_DB_NAME=Agricult
MONGO_COLLECTION_READINGS=sensor_readings
MONGO_COLLECTION_DAILY=daily_summaries

# ── Weather API (OpenWeatherMap) ──────────────────────────────
# Step 1: Go to https://openweathermap.org/api
# Step 2: Sign up for FREE account
# Step 3: Go to API Keys tab → copy your key → paste below
# Free tier: 1,000 calls/day (we use ~144/day with caching)
WEATHER_API_KEY=your_openweathermap_api_key_here
WEATHER_CITY=Mahendranagar
WEATHER_COUNTRY_CODE=NP
WEATHER_CACHE_TTL=600

# ── Machine Learning ──────────────────────────────────────────
ML_MODELS_DIR=ml/saved_models
ML_DATASETS_DIR=ml/datasets
ML_CROP_MODEL_FILE=crop_recommendation_model.joblib
ML_FERT_MODEL_FILE=fertilizer_recommendation_model.joblib
ML_IRRIG_MODEL_FILE=irrigation_recommendation_model.joblib
ML_ENCODER_FILE=label_encoders.joblib
ML_SCALER_FILE=feature_scaler.joblib
ML_MIN_CONFIDENCE=0.45
